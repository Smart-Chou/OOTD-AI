# AI Fashion Assistant Environment Variables

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://fashion_user:fashion_password@localhost:5432/fashion_db

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# AI Services
GOOGLE_CLOUD_VISION_API_KEY=your-api-key
STABILITY_API_KEY=your-api-key
OPENAI_API_KEY=your-api-key

# Cost Control
MONTHLY_BUDGET_GOOGLE_VISION=500
MONTHLY_BUDGET_STABILITY_AI=300
MONTHLY_BUDGET_TOTAL=1000

# Feature Flags
FEATURE_AI_CLOTHING_DETECTION=true
FEATURE_AI_OUTFIT_RECOMMENDATION=true
FEATURE_AI_VIRTUAL_TRYON=true
